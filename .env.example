# =============================================================================
# obsLab — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed.
# Variables are consumed by infra/docker-compose.yml and infra/docker-compose.dev.yml.
#
# NOTE: docker-compose reads .env from its own directory (infra/) OR from the
# project root if launched with --env-file. The Dockerfiles hardcode
# NODE_ENV=production; the dev compose file overrides it to development.
# There is no need to set NODE_ENV here.
# =============================================================================

# --- PostgreSQL container ----------------------------------------------------
# Credentials and database name for the postgres:16-alpine container.
POSTGRES_USER=db-user
POSTGRES_PASSWORD=db_passwd
POSTGRES_DB=obslab

# --- Prisma / Orchestrator database connection -------------------------------
# Used by Prisma CLI (migrations, seed) and by the orchestrator at runtime.
# Must match the POSTGRES_* values above plus the Docker service name "postgres".
DATABASE_URL=postgresql://db-user:db-passwd@postgres:5432/obslab?schema=public

# --- Service discovery (Docker networking) -----------------------------------
# Internal URLs used by services to reach each other inside the Docker network.
# Only change these if you rename services in docker-compose.yml.
SVC_ALPHA_URL=http://svc-alpha:3011
SVC_BETA_URL=http://svc-beta:3012
SVC_GAMMA_URL=http://svc-gamma:3013
WEB_URL=http://web:3000
ORCHESTRATOR_URL=http://orchestrator:3001
ORCHESTRATOR_SELF_URL=http://orchestrator:3001

# --- Ports -------------------------------------------------------------------
# Host-side ports exposed by docker-compose. Changing these also requires
# updating the port mappings in docker-compose.yml.
ORCHESTRATOR_PORT=3001
WORKER_PORT=3011

# --- Feature flags -----------------------------------------------------------
# Set to "false" to disable Swagger UI (/docs) on orchestrator and workers.
# Enabled by default; typically disabled in production.
# ENABLE_SWAGGER=true
