{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@obslab/shared": ["packages/shared/src"],
      "@obslab/shared/*": ["packages/shared/src/*"],
      "@obslab/db": ["packages/db/src"],
      "@obslab/db/*": ["packages/db/src/*"]
    }
  }
}
